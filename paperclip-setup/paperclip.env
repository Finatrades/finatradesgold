# ============================================================
# Paperclip AI — Environment Variables
# Fill in your values before running 1-setup.sh
# ============================================================

# Your Groq API key (from console.groq.com/keys)
# This is used instead of OpenAI — Groq is faster & cheaper
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# The AI model Paperclip agents will use
# Options:
#   meta-llama/llama-4-scout-17b-16e-instruct  (fast, good for agents)
#   llama-3.3-70b-versatile                    (smarter, slower)
#   mixtral-8x7b-32768                         (good balance)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Your domain name (if you have one) — leave blank to use the server IP
# Example: APP_DOMAIN=agents.finatrades.com
APP_DOMAIN=

# Full public URL of your Paperclip install
# Example: APP_URL=https://agents.finatrades.com
#          APP_URL=http://72.60.41.73  (if no domain yet)
APP_URL=http://72.60.41.73
